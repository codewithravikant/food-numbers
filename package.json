{
  "name": "numbers-dont-lie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath githooks || true",
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "test": "node --import tsx --test src/**/*.test.ts",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "deps:update": "npm update",
    "deps:latest:next": "npm i next@latest",
    "deps:refresh": "rm -rf node_modules package-lock.json && npm install",
    "env.encrypt": "node scripts/env-crypto.mjs encrypt",
    "env.decrypt": "node scripts/env-crypto.mjs decrypt",
    "security:backfill-shadow": "node --import tsx scripts/backfill-shadow-encryption.ts",
    "exercises:setup": "bash scripts/exercises/setup.sh",
    "exercises:fetch": "scripts/exercises/.venv/bin/python scripts/exercises/fetch_wger.py",
    "exercises:download-media": "scripts/exercises/.venv/bin/python scripts/exercises/download_media.py",
    "exercises:validate": "python3 scripts/exercises/validate_dataset.py"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "ci": "^2.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.24.0",
    "otplib": "^13.4.0",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "react-is": "^19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "smtp-client": "^0.4.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
